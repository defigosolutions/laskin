# ==========================================
# LA Skin & Aesthetics - Example Env
# ==========================================

# ------------------------------------------
# Backend Configuration
# ------------------------------------------
NODE_ENV="development"
PORT=4000

# Database
# Replace with your local or staging PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/laskin?schema=public"

# Security & JWT
# Generate secure random strings for these in production (e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET="your_development_access_secret_here"
JWT_REFRESH_SECRET="your_development_refresh_secret_here"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS
# The exact domain of your frontend
CORS_ORIGIN="http://localhost:5173"

# Audit Logs
# How long to keep audit logs before archiving or deleting
AUDIT_RETENTION_DAYS="30"

# Uploads
UPLOAD_DIR="./data/uploads"
UPLOAD_MAX_SIZE_BYTES="10485760" # 10MB
UPLOAD_BASE_URL="http://localhost:4000"

# Swagger
SWAGGER_ENABLED="true"

# ------------------------------------------
# Frontend Configuration
# ------------------------------------------
# The public API URL that the React frontend will call
VITE_API_BASE_URL="http://localhost:4000/api/v1"
